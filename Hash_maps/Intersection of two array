class Solution {
public:
    vector<int> intersection(vector<int>& nums1, vector<int>& nums2) {
        unordered_set <int> s;
        unordered_set <int> s1;
        for(int n:nums1){
            s.insert(n);
        }
        for(int i:nums2){
            if(s.find(i)!=s.end()){
                s1.insert(i);
            }
        }
        nums1.clear();
        for(int g:s1){
            nums1.push_back(g);
        }
        return nums1;
    }
};